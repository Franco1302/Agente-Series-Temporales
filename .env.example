OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TEMPERATURE=0.2
OLLAMA_REQUEST_TIMEOUT=8
CHAT_SYSTEM_PROMPT=Eres un asistente de IA útil especializado en análisis de data drift.
CHAT_MAX_CONTEXT_TURNS=8
CHAT_SUMMARY_MAX_CHARS=1400
RAG_TOP_K=8
RAG_KEEP_TOP=4
RAG_SUMMARY_MAX_SENTENCES=5
RAG_SUMMARY_MAX_CHARS=900
# Recuperacion RAG: tipo de busqueda (PlanMejoraRAG pasos 3-4)
# RAG_SEARCH_TYPE: similarity | mmr | hybrid
RAG_SEARCH_TYPE=hybrid
# RAG_FETCH_K: candidatos que MMR / hibrido rescatan antes de fusionar
RAG_FETCH_K=20
# RAG_MMR_LAMBDA: 1.0 = solo relevancia, 0.0 = solo diversidad
RAG_MMR_LAMBDA=0.5
# RAG_HYBRID_WEIGHTS: pesos "densa,lexica" de la fusion RRF (barrido: 0.7/0.3)
RAG_HYBRID_WEIGHTS=0.7,0.3
# RAG_RRF_K: amortiguacion RRF; barrido sobre este corpus eligio 5 (estandar=60)
RAG_RRF_K=5

# ── MCP / API analítica ──
DRIFT_API_URL=http://localhost:8017
# Timeout de lectura por-request (s). SARIMAX (forecast) hace grid search con
# backtesting refit por cada columna → puede superar 60s; 300s da margen.
DRIFT_API_TIMEOUT=300
DRIFT_API_CONNECT_TIMEOUT=5
MCP_WORKSPACE_DIR=data/temp_uploads
MCP_LOG_LEVEL=INFO

# ── Observabilidad ──
# Si está en `true` se escriben trazas JSON Lines en data/logs/agent.jsonl
OBSERVABILITY_ENABLED=false
# DEBUG duplica la salida a stderr; INFO solo escribe al fichero
LOG_LEVEL=INFO
