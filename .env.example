OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TEMPERATURE=0.2
OLLAMA_REQUEST_TIMEOUT=8
CHAT_SYSTEM_PROMPT=Eres un asistente de IA útil especializado en análisis de data drift.
CHAT_MAX_CONTEXT_TURNS=8
CHAT_SUMMARY_MAX_CHARS=1400
RAG_TOP_K=8
RAG_KEEP_TOP=4
RAG_SUMMARY_MAX_SENTENCES=5
RAG_SUMMARY_MAX_CHARS=900

# ── MCP / API analítica ──
DRIFT_API_URL=http://localhost:8017
DRIFT_API_TIMEOUT=60
DRIFT_API_CONNECT_TIMEOUT=5
MCP_WORKSPACE_DIR=data/temp_uploads
MCP_LOG_LEVEL=INFO

# ── Observabilidad ──
# Si está en `true` se escriben trazas JSON Lines en data/logs/agent.jsonl
OBSERVABILITY_ENABLED=false
# DEBUG duplica la salida a stderr; INFO solo escribe al fichero
LOG_LEVEL=INFO
